<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets" 
        xmlns:gap="http://phonegap.com/ns/1.0" 
        id="com.bincom.incidentapp" 
        version="1.0.0">
    
    <name>Incident Reporter</name>
    <description>Citizen Incident Reporting App for Bincom Academy</description>
    <author email="test@bincom.net">Your Name</author>
    
    <!-- App Preferences -->
    <preference name="permissions" value="none" />
    <preference name="orientation" value="portrait" />
    <preference name="fullscreen" value="false" />
    <preference name="android-minSdkVersion" value="22" />
    <preference name="android-targetSdkVersion" value="33" />
    <preference name="SplashScreenDelay" value="2000" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="ShowSplashScreenSpinner" value="true" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="500" />
    
    <!-- Required Plugins -->
    <plugin name="cordova-plugin-camera" />
    <plugin name="cordova-plugin-geolocation" />
    <plugin name="cordova-plugin-dialogs" />
    <plugin name="cordova-plugin-vibration" />
    <plugin name="cordova-plugin-splashscreen" />
    
    <!-- ========== APP ICON ========== -->
    <icon src="www/res/icon.png" />
    
    <!-- ========== SPLASH SCREEN ========== -->
    <splash src="www/res/splash.png" />
    
    <!-- Internet Access -->
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="geo:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="tel:*" />
    
</widget>
